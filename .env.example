# Copy to .env and adjust the values before the first start.

POSTGRES_DB=happy_server
POSTGRES_USER=happy
POSTGRES_PASSWORD=change-this-postgres-password

# Official docs still call this SEED. Current code maps it to HANDY_MASTER_SECRET.
SEED=change-this-to-a-long-random-secret

# Keep localhost-only for v1. If you need LAN access before Nginx, replace
# 127.0.0.1 with a specific LAN IP and update HAPPY_PUBLIC_URL to match.
HAPPY_BIND_ADDRESS=127.0.0.1
HAPPY_PORT=3005

# Local-only metrics endpoint for observability.
HAPPY_METRICS_BIND_ADDRESS=127.0.0.1
HAPPY_METRICS_PORT=9090

# Update this to the final HTTPS URL in phase 2 when Nginx is in front.
HAPPY_PUBLIC_URL=http://127.0.0.1:3005
